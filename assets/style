:root{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#16231b;background:#f5f7f5;--green:#166534;--light:#dcfce7;--border:#d7ded9}*{box-sizing:border-box}body{margin:0}.topbar{background:var(--green);color:#fff;padding:18px max(18px,calc((100% - 850px)/2));display:flex;justify-content:space-between;align-items:center}.topbar h1{margin:0;font-size:1.55rem}.topbar p{margin:3px 0 0;opacity:.85}.container{max-width:850px;margin:auto;padding:18px}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:18px}.tab,.secondary,.primary,.icon-btn{border:0;border-radius:12px;padding:11px 14px;font:inherit;cursor:pointer}.tab{background:#fff;border:1px solid var(--border)}.tab.active{background:var(--green);color:#fff}.panel{display:none}.panel.active{display:block}.section-head{display:flex;gap:12px;align-items:center;justify-content:space-between}.section-head h2,.panel h2{margin-bottom:3px}.section-head p{margin-top:0;color:#5c6860}.secondary{background:#fff;border:1px solid var(--border)}.primary{background:var(--green);color:#fff;font-weight:650}.list{display:grid;gap:12px;margin-top:14px}.card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:15px}.card-head{display:flex;justify-content:space-between;gap:12px}.card h3{margin:0}.muted{color:#657269;font-size:.92rem}.price{font-size:1.3rem;font-weight:750;color:var(--green)}.badge{display:inline-block;padding:4px 8px;border-radius:999px;background:var(--light);color:var(--green);font-size:.8rem}.actions{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}.danger{background:#fff0f0;color:#991b1b;border:1px solid #fecaca;border-radius:10px;padding:8px 10px;cursor:pointer}.chips{display:flex;gap:7px;overflow:auto;padding:5px 0}.chip{white-space:nowrap;border:1px solid var(--border);background:#fff;padding:7px 10px;border-radius:999px;cursor:pointer}.chip.active{background:var(--light);border-color:#86efac}.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:14px 0}label{display:grid;gap:6px;font-weight:600}input,select{width:100%;padding:12px;border:1px solid var(--border);border-radius:12px;background:#fff;font:inherit}.status{min-height:1.4em}.notice{background:#fff7d6;border:1px solid #f1d67b;padding:12px;border-radius:12px;margin-bottom:12px}.hidden{display:none!important}.empty{text-align:center;padding:28px;color:#657269;background:#fff;border:1px dashed var(--border);border-radius:16px}dialog{width:min(92vw,480px);border:0;border-radius:18px;padding:18px}dialog::backdrop{background:#0007}.dialog-head{display:flex;justify-content:space-between;align-items:center}.dialog-head h2{margin:0}.icon-btn{background:#ffffff26;color:inherit;font-size:1.1rem}.help{font-size:.85rem;color:#657269}.toast{position:fixed;left:50%;bottom:20px;transform:translate(-50%,120px);background:#172019;color:#fff;padding:11px 16px;border-radius:12px;transition:.25s;max-width:90%;z-index:10}.toast.show{transform:translate(-50%,0)}a{color:var(--green)}@media(max-width:620px){.form-grid{grid-template-columns:1fr}.container{padding:13px}.section-head{align-items:flex-start}.topbar{padding:16px}.tab{padding:10px 5px}.card-head{flex-direction:column}.price{font-size:1.15rem}}
